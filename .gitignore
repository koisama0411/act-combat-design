# ── output/ 产出区 ──────────────────────────────────────────────
# 你自己生成的设计稿默认不纳入版本控制;但仓库自带的示例产出
# (output/characters/cang-lan、output/bosses/gu-ya)要保留追踪。
output/*
!output/README.md
!output/characters/
!output/bosses/

output/characters/*
!output/characters/.gitkeep
!output/characters/cang-lan/
!output/characters/jin-yu/

output/bosses/*
!output/bosses/.gitkeep
!output/bosses/gu-ya/

# 脚本临时产出
scripts/output/
*.tmp
*.log
~$*

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/

# ── knowledge-local/ 本地知识区 ─────────────────────────────────
# 下游用户 agent 在本地积累的知识（自我更新 + 项目指定知识）默认不纳入版本控制；
# 只保留目录骨架 + README + .gitkeep，捕获内容留各自本地。
knowledge-local/self-update/*
!knowledge-local/self-update/.gitkeep
knowledge-local/project-knowledge/*
!knowledge-local/project-knowledge/.gitkeep
